# MiniMax API
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id
MINIMAX_DEFAULT_MODEL=minimax-m2.5
MINIMAX_FAST_MODEL=minimax-m2.5-lightning

# Supervisor (Mac)
SUPERVISOR_URL=http://mac-ip:3000
SUPERVISOR_API_KEY=your-supervisor-api-key

# Database
DATABASE_URL=postgresql://agent:password@localhost:5432/countable

# Redis
REDIS_URL=redis://localhost:6379

# OpenClaw v2026.2.12
OPENCLAW_VERSION=2026.2.12
OPENCLAW_HOOKS_DEFAULT_SESSION_KEY=agent-orchestrator
OPENCLAW_HOOKS_ALLOW_REQUEST_SESSION_KEY=false
OPENCLAW_SANDBOX_SKILLS_ENABLED=true
OPENCLAW_SESSION_ISOLATION=true
OPENCLAW_ENABLE_SSRF_PROTECTION=true
OPENCLAW_ENABLE_PATH_VALIDATION=true

# x402 Payment (EVM — Base mainnet)
X402_SELLER_WALLET=  # EVM wallet address (0x...) to receive USDC payments
X402_PRICE_ATOMIC=1000  # USDC atomic units (1000 = 0.001 USDC)

# x402 Payment (Solana)
X402_SOLANA_SELLER_WALLET=  # Solana wallet address (base58) to receive USDC payments
X402_SOLANA_PRICE_ATOMIC=1000  # USDC atomic units (1000 = 0.001 USDC)

# Monitoring (healthchecks.io or similar dead-man's switch)
HEALTHCHECK_PING_URL=https://hc-ping.com/YOUR-UUID-HERE

# Dashboard
NEXT_PUBLIC_DASHBOARD_POLL_INTERVAL_MS=30000  # How often the dashboard auto-refreshes in milliseconds (default: 30s)
